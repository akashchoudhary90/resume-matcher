# Copy to `.env` in THIS directory (deploy/cohost/.env) and fill in. `.env` is git-ignored, so it
# stays on the VPS and `git pull` never touches it. Compose auto-loads it from here.
#   cp deploy/cohost/.env.example deploy/cohost/.env && chmod 600 deploy/cohost/.env
RM_ADMIN_USER=admin
# REQUIRED — set a strong password before deploying. With RM_ENV=prod (below) the app REFUSES TO
# START if this is unset or a known-weak default (admin / password / changeme / CHANGE_ME_BEFORE_
# DEPLOY / secret / 123456). Without RM_ENV=prod it only logs a warning, so the synthetic-data demo
# stays usable with admin/admin.
RM_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
HOSTINGER_API_TOKEN=your-hostinger-dns-api-token-here

# --- Prod posture (Phase-5 A15/A16). RM_ENV=prod makes the two guards above fail-CLOSED. ---
# A container that refuses to start never goes healthy, so scripts/deploy.{sh,ps1} report it as a
# failed deploy (and --remote rolls back). Check `docker logs rmdemo-app` for the RuntimeError.
# NOT YET LIVE ON THIS STACK: docker-compose.cohost.yml does not forward RM_ENV to the container, so
# setting it here has no effect until that `environment:` block gains `RM_ENV: "${RM_ENV:-}"`. Doing
# so is the recorded gate for turning the demo into a real deployment — the app-side refusal is
# built and tested (tests/test_require_role.py), the compose wiring is the deliberate last step, so
# that flipping it is a considered act rather than a side effect of an upgrade.
# RM_ENV=prod
# Session cookies are HTTPS-only. RM_ENV=prod refuses to start if this is explicitly set to 0;
# leaving it UNSET keeps the pre-A16 default (the compose file already defaults it to 1).
RM_COOKIE_SECURE=1
# Admin sign-in is a SERVER-SIDE session (admin_sessions), not a cookie derived from the password:
#   * /api/logout really destroys it — a captured cookie dies with the row;
#   * it expires server-side after RM_ADMIN_SESSION_HOURS (default 12) and is swept by retention;
#   * ROTATING RM_ADMIN_PASSWORD AND REDEPLOYING LOGS EVERY ADMIN SESSION OUT AT ONCE — that is the
#     incident-response move if a cookie or the password is ever suspected leaked. It needs no code
#     change and no compose change: the password already IS forwarded.
# RM_ADMIN_SESSION_HOURS=12   # same compose-forwarding caveat as RM_ENV above; app default is 12

# --- Optional: Claude matching engine on your SUBSCRIPTION (no API key, no per-token bill) ---
# 1) On a machine logged into Claude Code, run:  claude setup-token
# 2) Paste the token here, then redeploy. Until it's set, the demo uses the deterministic engine.
# (Heads-up: with the Claude engine, resume text is sent to Anthropic via your subscription session.)
CLAUDE_CODE_OAUTH_TOKEN=
# RM_DEMO_BACKEND=claude_cli      # default already claude_cli in compose; set to "mock" to force off
# RM_CLAUDE_CLI_MODEL=sonnet      # or "haiku" for faster/cheaper-on-quota matching
# RM_DEMO_CONCURRENCY=4           # parallel resume extractions per upload
