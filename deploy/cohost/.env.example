# Copy to `.env` in THIS directory (deploy/cohost/.env) and fill in. `.env` is git-ignored, so it
# stays on the VPS and `git pull` never touches it. Compose auto-loads it from here.
#   cp deploy/cohost/.env.example deploy/cohost/.env && chmod 600 deploy/cohost/.env
RM_ADMIN_USER=admin
# REQUIRED — set a strong password before deploying. The app REFUSES TO START if this is left at a
# known-weak default (admin / password / changeme / CHANGE_ME_BEFORE_DEPLOY).
RM_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
HOSTINGER_API_TOKEN=your-hostinger-dns-api-token-here

# --- Optional: Claude matching engine on your SUBSCRIPTION (no API key, no per-token bill) ---
# 1) On a machine logged into Claude Code, run:  claude setup-token
# 2) Paste the token here, then redeploy. Until it's set, the demo uses the deterministic engine.
# (Heads-up: with the Claude engine, resume text is sent to Anthropic via your subscription session.)
CLAUDE_CODE_OAUTH_TOKEN=
# RM_DEMO_BACKEND=claude_cli      # default already claude_cli in compose; set to "mock" to force off
# RM_CLAUDE_CLI_MODEL=sonnet      # or "haiku" for faster/cheaper-on-quota matching
# RM_DEMO_CONCURRENCY=4           # parallel resume extractions per upload
